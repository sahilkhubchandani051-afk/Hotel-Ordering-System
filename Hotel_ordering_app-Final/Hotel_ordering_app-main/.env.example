# Environment Configuration
# Copy this file to .env and update with your values

# Application Settings
ENVIRONMENT=development
PORT=8000
APP_BASE_URL=https://your-domain.com

# Security
SESSION_SECRET_KEY=your-super-secret-key-change-this-in-production

# Admin Credentials
ADMIN_EMAIL=admin@hotel.com
ADMIN_PASSWORD=admin123

# Supabase Configuration (Required - app will NOT start without these)
# IMPORTANT: Use the SERVICE ROLE KEY (not the anon key) - required for Auth admin operations
# SUPABASE_KEY is accepted as an alias for SUPABASE_SERVICE_ROLE_KEY
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database (PostgreSQL - for production)
# DATABASE_URL will be automatically set by Render from the database service
DATABASE_URL=postgresql://user:password@host:port/dbname
